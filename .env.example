# LLM Providers (at least one required)
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Default models (optional)
GROQ_MODEL=llama3-70b-8192
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# GitHub (optional — raises rate limit to 5000 req/hr for PUBLIC repos and
# is used as the anonymous-clone fallback). Private repos use the logged-in
# user's OAuth token, NOT this one.
GITHUB_TOKEN=ghp_your_github_token_here

# ---------- Auth (GitHub OAuth App + session encryption) ----------
# Create a GitHub OAuth App at: https://github.com/settings/developers
#   - Callback URL: http://localhost:5173/auth/callback (dev)
#                   http://<your-host>/auth/callback     (prod)
# Note: the `repo` scope grants read+write to all repos the user can access.
# There's no read-only OAuth App scope — this is a GitHub limitation.
GITHUB_OAUTH_CLIENT_ID=your_oauth_client_id_here
GITHUB_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# Secret used to sign session cookies. Any long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change_me_to_a_long_random_string

# Fernet key for encrypting stored GitHub tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_to_a_fernet_key

# (Optional) Set to 1 to mark session cookies Secure (HTTPS only). Production
# behind TLS should set this; plain-HTTP deployments must leave it 0.
SESSION_COOKIE_SECURE=0

# (Optional) Max session cookie age in seconds. 0/empty = browser-session
# (cleared on browser close). Set to 2592000 for a 30-day "remember me".
# SESSION_COOKIE_MAX_AGE=2592000

# (Optional) Comma-separated list of allowed CORS origins. Defaults to
# http://localhost:5173,http://127.0.0.1:5173 for local Vite dev. In the
# Docker single-port deployment the frontend is same-origin so this isn't
# needed, but list your dev origin(s) here.
# CORS_ALLOW_ORIGINS=http://localhost:5173

# (Optional) Where to send the browser after login/logout. Defaults to "/"
# (same-origin). For local Vite dev set this to http://localhost:5173.
# FRONTEND_ORIGIN=http://localhost:5173

# Embedding provider: "local" (in-process nomic on CPU/GPU, free) or
# "openrouter" (Qwen3-Embedding-8B via the OpenRouter API, ~$0.01/1M tokens).
# "openrouter" reuses OPENROUTER_API_KEY above.
# EMBEDDING_PROVIDER=local
